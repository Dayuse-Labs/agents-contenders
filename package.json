{
  "name": "agent-contenders",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "verify": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@google/genai": "^1.30.0",
    "@prisma/client": "^6.2.0",
    "next": "^15.3.0",
    "next-auth": "^5.0.0-beta.25",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@eslint/eslintrc": "^3.2.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.0",
    "@vitest/coverage-v8": "^2.1.0",
    "prettier": "^3.4.0",
    "prisma": "^6.2.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
