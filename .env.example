# ─── Lyria / Gemini ─────────────────────────────────────────────
# Clé API Gemini (https://aistudio.google.com/apikey). Jamais commitée.
GEMINI_API_KEY=

# ─── Base de données (Postgres managé Railway) ──────────────────
DATABASE_URL=postgresql://user:password@host:5432/agent_contenders

# ─── Auth.js / SSO Google Workspace ─────────────────────────────
# Secret de session : openssl rand -base64 32
AUTH_SECRET=
# OAuth client (Google Cloud Console → Credentials → OAuth client ID, type Web)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Domaine Workspace autorisé (vérification du claim hd). Sépare par des virgules si plusieurs.
ALLOWED_HD=dayuse.com
# Emails autorisés à créer/générer des battles (séparés par des virgules)
ADMIN_EMAILS=fabien.d@dayuse.com

# ─── Stockage audio (volume Railway monté) ──────────────────────
AUDIO_DIR=/data/audio

# ─── Anti-doublon de vote (sel pour hacher les emails) ──────────
# openssl rand -base64 32
VOTE_SALT=

# ─── URL publique de l'app (pour les liens/QR et le callback OAuth)
APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
